# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App origin (used by the auth callback to build the post-login redirect
# host). MUST be set in production — the callback refuses to trust
# x-forwarded-host blindly. In dev this is optional (the request origin
# is used). Example: https://productbuilders.app
NEXT_PUBLIC_SITE_URL=

# Cron job authentication (generate with: openssl rand -base64 32)
CRON_SECRET=your-cron-secret
